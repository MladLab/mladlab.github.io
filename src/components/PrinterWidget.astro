---
const API_URL = 'http://95.87.148.212:9988/api/v1/print-log/?limit=500';
const API_KEY = 'bb_c-KPvHVRAYKY4mJA7t1zQSu76w129RwyQnCmfFRXDM0';

let stats: {
  kg: string; hours: string; prints: number; successPct: number;
  avg: string; longest: string; topPrinter: string; printerCount: number;
  since: string;
  mats: { name: string; kg: string; pct: number }[];
} | null = null;

try {
  const res = await fetch(API_URL, { headers: { 'X-Api-Key': API_KEY } });
  if (!res.ok) throw new Error('bad status');
  const { items } = await res.json();

  const completed  = items.filter((i: any) => i.status === 'completed');
  const withGrams  = completed.filter((i: any) => i.filament_used_grams > 0);
  const totalG     = withGrams.reduce((s: number, i: any) => s + i.filament_used_grams, 0);
  const totalSec   = items.reduce((s: number, i: any) => s + (i.duration_seconds || 0), 0);
  const nonNull    = items.filter((i: any) => i.status !== null);
  const successPct = nonNull.length ? Math.round((completed.length / nonNull.length) * 100) : 0;
  const avgG       = withGrams.length ? totalG / withGrams.length : 0;
  const longestSec = Math.max(...items.map((i: any) => i.duration_seconds || 0));

  const matMap: Record<string, number> = {};
  withGrams.forEach((i: any) => {
    const t = i.filament_type || 'Neznano';
    matMap[t] = (matMap[t] || 0) + i.filament_used_grams;
  });
  const matTotal = Object.values(matMap).reduce((s, v) => s + v, 0);
  const mats = Object.entries(matMap)
    .sort((a, b) => b[1] - a[1])
    .map(([name, g]) => ({ name, kg: (g / 1000).toFixed(2), pct: Math.round((g / matTotal) * 100) }));

  const pCounts: Record<string, number> = {};
  items.forEach((i: any) => { pCounts[i.printer_name] = (pCounts[i.printer_name] || 0) + 1; });
  const [topName, topCount] = Object.entries(pCounts).sort((a, b) => b[1] - a[1])[0] ?? ['—', 0];

  const dates = items.map((i: any) => new Date(i.started_at)).filter(Boolean);
  const earliest = new Date(Math.min(...dates.map((d: Date) => d.getTime())));
  const since = earliest.toLocaleDateString('sl-SI', { day: 'numeric', month: 'numeric', year: 'numeric' });

  stats = {
    kg: (totalG / 1000).toFixed(2),
    hours: (totalSec / 3600).toFixed(0),
    prints: completed.length,
    successPct,
    avg: `${avgG.toFixed(0)} g`,
    longest: `${(longestSec / 3600).toFixed(1)} h`,
    topPrinter: `${topName} (${topCount}×)`,
    printerCount: Object.keys(pCounts).length,
    since,
    mats,
  };
} catch {
  // stats stays null → show error state
}

const barColors = ['bg-lab-orange', 'bg-lab-text', 'bg-green-400', 'bg-blue-400'];
const textColors = ['text-lab-orange', 'text-lab-text', 'text-green-400', 'text-blue-400'];

const builtAt = new Date().toLocaleDateString('sl-SI', { day: 'numeric', month: 'numeric', year: 'numeric' });
---

<div class="bg-lab-surface border border-lab-border rounded-lg p-5">

  <!-- Header -->
  <div class="flex items-center justify-between mb-5">
    <span class="text-xs font-semibold uppercase tracking-widest text-lab-muted">3D Farm · statistika (od 5.5.2026)</span>
    <span class="text-xs text-lab-muted">posodobljeno {builtAt}</span>
  </div>

  {!stats && <p class="text-sm text-lab-muted italic">podatki nedosegljivi</p>}

  {stats && (
    <div>
      <!-- Big numbers -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-5">
        <div>
          <div class="text-2xl font-bold text-lab-orange">{stats.kg}</div>
          <div class="text-xs text-lab-muted mt-0.5">kg filamenta</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lab-text">{stats.hours}</div>
          <div class="text-xs text-lab-muted mt-0.5">ur tiskanja</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lab-text">{stats.prints}</div>
          <div class="text-xs text-lab-muted mt-0.5">dokončanih tiskov</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lab-text">{stats.successPct}%</div>
          <div class="text-xs text-lab-muted mt-0.5">uspešnost</div>
        </div>
      </div>

      <!-- Material split + fun facts -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 border-t border-lab-border pt-4">

        <!-- Materials -->
        <div>
          <div class="text-xs text-lab-muted mb-2">Material</div>
          <div class="flex flex-col gap-1.5">
            {stats.mats.map((m, i) => (
              <div>
                <div class="flex justify-between text-xs mb-0.5">
                  <span class={textColors[i] ?? 'text-lab-muted'}>{m.name}</span>
                  <span class="text-lab-muted">{m.kg} kg · {m.pct}%</span>
                </div>
                <div class="h-1 bg-lab-border rounded-full overflow-hidden">
                  <div class={`${barColors[i] ?? 'bg-lab-muted'} h-full rounded-full`} style={`width:${m.pct}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Fun facts -->
        <div class="flex flex-col gap-1.5">
          <div class="text-xs text-lab-muted mb-0.5">Zanimivosti</div>
          <div class="text-xs text-lab-muted flex justify-between">
            <span>Povprečen tisk</span>
            <span class="text-lab-text">{stats.avg}</span>
          </div>
          <div class="text-xs text-lab-muted flex justify-between">
            <span>Najdaljši tisk</span>
            <span class="text-lab-text">{stats.longest}</span>
          </div>
          <div class="text-xs text-lab-muted flex justify-between">
            <span>Največ tiskov</span>
            <span class="text-lab-text truncate max-w-[12rem]">{stats.topPrinter}</span>
          </div>
          <div class="text-xs text-lab-muted flex justify-between">
            <span>Skupaj tiskalnikov</span>
            <span class="text-lab-text">{stats.printerCount}</span>
          </div>
        </div>
      </div>
    </div>
  )}
</div>
