---
interface Props {
  slug: string;
  naslov: string;
  avtor: string;
  authorSlug?: string;
  datum: Date;
  tags: string[];
  opis: string;
  slika?: string;
}

const { slug, naslov, avtor, authorSlug, datum, tags, opis, slika } = Astro.props;

const dateStr = datum.toLocaleDateString('sl-SI', { day: 'numeric', month: 'numeric', year: 'numeric' });
---

<article
  class="bg-lab-surface border border-lab-border rounded hover:border-lab-orange transition-colors group flex flex-col"
  data-tags={tags.join(',')}
>
  {slika && (
    <a href={`/projekti/${slug}`} class="block aspect-video overflow-hidden rounded-t bg-lab-edge">
      <img src={slika} alt={naslov} class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity" loading="lazy" />
    </a>
  )}
  {!slika && (
    <a href={`/projekti/${slug}`} class="block aspect-video rounded-t bg-lab-edge flex items-center justify-center hover:bg-lab-border transition-colors">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2a2a2a" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
    </a>
  )}
  <div class="p-4 flex flex-col gap-2 flex-1">
    <h3 class="font-semibold leading-snug">
      <a href={`/projekti/${slug}`} class="text-lab-text hover:text-lab-orange transition-colors">
        {naslov}
      </a>
    </h3>
    <p class="text-xs text-lab-muted line-clamp-2">{opis}</p>
    <div class="flex flex-wrap gap-1 mt-auto pt-2">
      {tags.map(tag => (
        <a
          href={`/projekti?tag=${encodeURIComponent(tag)}`}
          class="text-xs px-1.5 py-0.5 rounded-sm bg-lab-edge text-lab-muted border border-lab-border hover:border-lab-orange hover:text-lab-text transition-colors"
        >
          {tag}
        </a>
      ))}
    </div>
    <div class="flex justify-between items-center text-xs text-lab-muted pt-1">
      {authorSlug
        ? <a href={`/clani/${authorSlug}`} class="hover:text-lab-orange transition-colors">{avtor}</a>
        : <span>{avtor}</span>
      }
      <span>{dateStr}</span>
    </div>
  </div>
</article>
