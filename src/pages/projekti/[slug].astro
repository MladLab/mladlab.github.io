---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const members = await getCollection('members');
const memberMap = Object.fromEntries(members.map(m => [m.data.ime, m.slug]));

const machines = await getCollection('machines');
const machineMap = Object.fromEntries(machines.map(m => [m.data.ime, m.slug]));

const dateStr = project.data.datum.toLocaleDateString('sl-SI', { day: 'numeric', month: 'numeric', year: 'numeric' });
---

<Base title={project.data.naslov}>
  <div class="max-w-3xl mx-auto px-4 py-12">

    <!-- Back -->
    <a href="/projekti" class="text-xs text-lab-muted hover:text-lab-orange transition-colors mb-8 inline-block">← Vsi projekti</a>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap gap-1 mb-3">
        {project.data.tags.map(tag => (
          <a
            href={`/projekti?tag=${encodeURIComponent(tag)}`}
            class="text-xs px-1.5 py-0.5 rounded-sm bg-lab-edge text-lab-muted border border-lab-border hover:border-lab-orange hover:text-lab-text transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
      <h1 class="text-3xl font-bold text-lab-text mb-4">{project.data.naslov}</h1>
      <div class="flex flex-wrap gap-6 text-xs text-lab-muted">
        <div>
          <span class="text-lab-orange mr-1">{project.data.avtor.length > 1 ? 'Avtorji' : 'Avtor'}</span>
          {project.data.avtor.map((name, i) => (
            <>
              {i > 0 && <span class="mr-0.5">,</span>}
              {memberMap[name]
                ? <a href={`/clani/${memberMap[name]}`} class="hover:text-lab-text transition-colors">{name}</a>
                : <span>{name}</span>
              }
            </>
          ))}
        </div>
        <div>
          <span class="text-lab-orange mr-1">Datum</span>
          {dateStr}
        </div>
      </div>
    </header>

    <!-- Hero image -->
    {project.data.slika && (
      <div class="mb-8 rounded-lg overflow-hidden border border-lab-border">
        <img src={project.data.slika} alt={project.data.naslov} class="w-full object-cover max-h-96" />
      </div>
    )}

    <!-- Machines used -->
    {project.data.stroji.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8 p-3 bg-lab-surface border border-lab-border rounded">
        <span class="text-xs text-lab-muted mr-1">Stroji:</span>
        {project.data.stroji.map(ime => {
          const slug = machineMap[ime];
          return slug
            ? <a href={`/stroji/${slug}`} class="text-xs text-lab-orange hover:text-lab-orange2 transition-colors">{ime}</a>
            : <span class="text-xs text-lab-muted">{ime}</span>;
        })}
      </div>
    )}

    <!-- Content -->
    <div class="prose prose-invert prose-sm max-w-none text-lab-muted leading-relaxed
      [&_h2]:text-lab-text [&_h2]:font-semibold [&_h2]:text-base [&_h2]:mt-8 [&_h2]:mb-2
      [&_h3]:text-lab-text [&_h3]:font-semibold [&_h3]:text-sm [&_h3]:mt-6 [&_h3]:mb-1
      [&_a]:text-lab-orange [&_a:hover]:text-lab-orange2
      [&_strong]:text-lab-text
      [&_ol]:list-decimal [&_ol]:list-inside
      [&_ul]:list-disc [&_ul]:list-inside
      [&_li]:marker:text-lab-orange
      [&_code]:bg-lab-edge [&_code]:px-1 [&_code]:rounded [&_code]:text-xs [&_code]:text-lab-text
    ">
      <Content />
    </div>

    <!-- Gallery -->
    {(() => {
      const imgs = project.data.galerija.length > 0
        ? project.data.galerija
        : project.data.slika ? [project.data.slika] : [];
      return imgs.length > 0 && (
        <div class="mt-10 border-t border-lab-border pt-8">
          <h2 class="text-xs uppercase tracking-widest text-lab-muted mb-4">Galerija</h2>
          <div class="grid grid-cols-3 gap-2">
            {imgs.map(src => (
              <button
                class="rounded overflow-hidden border border-lab-border aspect-square cursor-zoom-in hover:border-lab-orange transition-colors"
                data-lightbox={src}
              >
                <img src={src} alt={project.data.naslov} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        </div>
      );
    })()}

  </div>
</Base>

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 p-4" role="dialog" aria-modal="true">
  <button id="lightbox-close" class="absolute top-4 right-5 text-white/60 hover:text-white text-2xl leading-none">✕</button>
  <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full object-contain rounded" />
</div>

<script>
  const lightbox  = document.getElementById('lightbox')!;
  const lbImg     = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbClose   = document.getElementById('lightbox-close')!;

  function open(src: string, alt: string) {
    lbImg.src = src;
    lbImg.alt = alt;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('[data-lightbox]').forEach(btn => {
    btn.addEventListener('click', () => open(btn.dataset.lightbox!, btn.querySelector('img')!.alt));
  });

  lbClose.addEventListener('click', close);
  lightbox.addEventListener('click', e => { if (e.target === lightbox) close(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
</script>
